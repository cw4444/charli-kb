# System
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# Local secrets
.env
.env.local
*.local.md

# Private keys and credentials
*.pem
*.key
*.p12
*.pfx
*.jks
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
credentials*
secrets.y*ml
auth.json

# Raw source material is local input for agents.
# Keep the folder docs/placeholders, but do not publish dumped sources by default.
raw/**
!raw/
!raw/README.md
!raw/.gitkeep
!raw/articles/
!raw/articles/.gitkeep
!raw/notes/
!raw/notes/.gitkeep
!raw/images/
!raw/images/.gitkeep
!raw/images/screenshots/
!raw/images/screenshots/.gitkeep
!raw/images/mindmaps/
!raw/images/mindmaps/.gitkeep
!raw/images/x-posts/
!raw/images/x-posts/.gitkeep

# Temporary files
*.tmp
*.bak
~$*
